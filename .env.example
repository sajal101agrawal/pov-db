DATABASE_URL=postgresql://pov:pov@localhost:5433/pov
REDIS_URL=redis://localhost:6380/0
APP_ENV=local
API_PREFIX=/api
DEFAULT_RISK_FREE_RATE=0.10
DATA_DIR=data
NSE_REQUEST_DELAY_SECONDS=0.35
SOURCE_RETRY_ATTEMPTS=3
SOURCE_RETRY_BASE_DELAY_SECONDS=0.75
SOURCE_RETRY_MAX_DELAY_SECONDS=8.0
PIPELINE_SYMBOL_LIMIT=
PIPELINE_COMPUTE_CONCURRENCY=4
LIVE_QUOTE_PROVIDER=yahoo
LIVE_OPTION_SUMMARY_PROVIDER=nse
LIVE_OPTION_SUMMARY_CONCURRENCY=2
LIVE_OPTION_SUMMARY_MIN_INTERVAL_SECONDS=0.25
LIVE_DHAN_OPTION_SUMMARY_BATCH_SIZE=25
LIVE_DHAN_OPTION_SUMMARY_BATCH_DELAY_SECONDS=3.0
LIVE_KITE_QUOTE_BATCH_SIZE=500
LIVE_KITE_QUOTE_BATCH_DELAY_SECONDS=1.1
LIVE_OPTION_CHAIN_PROVIDER=nse
LIVE_MARKET_QUOTE_MIN_INTERVAL_SECONDS=1.0
LIVE_OPTION_CHAIN_MIN_INTERVAL_SECONDS=3.0
LIVE_SYMBOLS=all
LIVE_POLL_INTERVAL_SECONDS=180
LIVE_CACHE_TTL_SECONDS=300
LIVE_MARKET_START_IST=09:00
LIVE_MARKET_END_IST=16:00
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=
DHAN_PIN=
DHAN_TOTP_SECRET=
DHAN_TOKEN_REFRESH_MARGIN_SECONDS=1800
KITE_CLIENT_ID=
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=
KITE_REQUEST_TOKEN=
KITE_AUTO_REFRESH_ENABLED=true
KITE_TOKEN_REFRESH_TIME_IST=06:05

# AWS S3 — ETL dump upload (optional; dump is skipped if S3_DUMP_BUCKET is empty)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_DUMP_BUCKET=
S3_DUMP_PREFIX=etl-dumps/
